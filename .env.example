# 环境变量示例（复制为 .env.local，勿提交密钥）

# ── LLM / AI 问道（P0，仅服务端；前端无密钥配置入口，避免泄露）──
# DeepSeek OpenAI 兼容：https://api.deepseek.com
# 文档模型：deepseek-v4-flash（快）/ deepseek-v4-pro（强）
DZ_LLM_BASE_URL=https://api.deepseek.com
DZ_LLM_API_KEY=
# 可与 DEEPSEEK_API_KEY 二选一；代码优先 DZ_LLM_API_KEY
# DEEPSEEK_API_KEY=

# 主模型（智能问道、复杂问答）
DZ_LLM_MODEL=deepseek-v4-pro
# 快速模型（划词释义、译文、插图 prompt）— 未设则用 deepseek-v4-flash
DZ_LLM_MODEL_FAST=deepseek-v4-flash

# 思考模式（DeepSeek 支持时设为 true）
# DZ_LLM_THINKING=true

# 匿名用户每日 AI 次数上限（未设则默认 5）
# DZ_AI_DAILY_QUOTA=5

# ── 开发工具 ────────────────────────────────────────────────
# 生产环境启用低置信度块审核页
# DZ_ENABLE_REVIEW=true

# ── P1 账号 / 数据库 ────────────────────────────────────────
# SQLite 本地库（默认 data/daozang.db）；也可 file:/path/to/db
# DATABASE_URL=file:./data/daozang.db
AUTH_SECRET=          # openssl rand -base64 32
# NEXTAUTH_SECRET=    # 与 AUTH_SECRET 二选一
# NEXTAUTH_URL=http://localhost:3000
